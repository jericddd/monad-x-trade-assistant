+"use client";
+
+import { useCallback, useEffect, useState } from "react";
+import {
+  useAccount,
+  useConnect,
+  useDisconnect,
+  useSendTransaction,
+  useSwitchChain,
+  useWaitForTransactionReceipt,
+} from "wagmi";
+import { parseEther } from "viem";
+import { useSignMessage } from "wagmi";
+import { ArrowDownUp, Check, Loader2, LogOut, Wallet } from "lucide-react";
+import { useAuth } from "@/components/providers/auth-provider";
+import { Button } from "@/components/ui/button";
+import { getExplorerTxUrl } from "@/lib/monad-chain";
+import { monadMainnet } from "@/lib/monad-chain";
+
+type TradeAccountPayload = {
+  linked: boolean;
+  needsWallet: boolean;
+  connectedWallet?: string;
+  account: {
+    inSiteWallet: `0x${string}`;
+    connectedWallet: `0x${string}`;
+    xUsername: string;
+  } | null;
+  balances?: {
+    inSiteMon: string;
+    connectedMon: string | null;
+  };
+  error?: string;
+};
+
+function shortAddr(addr: string): string {
+  return `${addr.slice(0, 6)}…${addr.slice(-4)}`;
+}
+
+function formatMon(value: string | null | undefined): string {
+  if (!value) return "—";
+  const n = Number(value);
+  if (!Number.isFinite(n)) return value;
+  if (n === 0) return "0";
+  if (n < 0.0001) return "<0.0001";
+  return n.toLocaleString(undefined, { maximumFractionDigits: 4 });
+}
+
+export function TradeDesk() {
+  const { user, loading: authLoading, logout } = useAuth();
+  const { address, isConnected, chainId } = useAccount();
+  const { connect, connectors, isPending: connecting } = useConnect();
+  const { disconnect } = useDisconnect();
+  const { switchChainAsync } = useSwitchChain();
+  const { signMessageAsync } = useSignMessage();
+  const { sendTransactionAsync, data: depositHash, isPending: depositing } = useSendTransaction();
+  const depositReceipt = useWaitForTransactionReceipt({ hash: depositHash });
+
+  const [account, setAccount] = useState<TradeAccountPayload | null>(null);
+  const [loadingAccount, setLoadingAccount] = useState(false);
+  const [verifying, setVerifying] = useState(false);
+  const [direction, setDirection] = useState<"deposit" | "withdraw">("deposit");
+  const [amount, setAmount] = useState("");
+  const [status, setStatus] = useState<string | null>(null);
+  const [txUrl, setTxUrl] = useState<string | null>(null);
+  const [busy, setBusy] = useState(false);
+
+  const refreshAccount = useCallback(async () => {
+    if (!user) {
+      setAccount(null);
+      return;
+    }
+    setLoadingAccount(true);
+    try {
+      const res = await fetch("/api/trade/account");
+      const data = (await res.json()) as TradeAccountPayload;
+      if (!res.ok) {
+        setStatus(data.error ?? "Could not load account");
+        setAccount(null);
+        return;
+      }
+      setAccount(data);
+    } catch {
+      setStatus("Could not load account");
+    } finally {
+      setLoadingAccount(false);
+    }
+  }, [user]);
+
+  useEffect(() => {
+    void refreshAccount();
+  }, [refreshAccount]);
+
+  useEffect(() => {
+    if (depositReceipt.isSuccess && depositHash) {
+      setStatus("Deposit confirmed");
+      setTxUrl(getExplorerTxUrl(depositHash));
+      void refreshAccount();
+    }
+  }, [depositReceipt.isSuccess, depositHash, refreshAccount]);
+
+  async function ensureMonad() {
+    if (chainId !== monadMainnet.id) {
+      await switchChainAsync({ chainId: monadMainnet.id });
+    }
+  }
+
+  async function verifyAndLink() {
+    if (!user || !address) return;
+    setVerifying(true);
+    setStatus(null);
+    setTxUrl(null);
+    try {
+      await ensureMonad();
+      const nonceRes = await fetch("/api/wallet", {
+        method: "POST",
+        headers: { "content-type": "application/json" },
+        body: JSON.stringify({ walletAddress: address }),
+      });
+      const nonceData = (await nonceRes.json()) as { message?: string; error?: string };
+      if (!nonceRes.ok || !nonceData.message) {
+        throw new Error(nonceData.error ?? "Could not start wallet verify");
+      }
+      const signature = await signMessageAsync({ message: nonceData.message });
+      const verifyRes = await fetch("/api/wallet", {
+        method: "POST",
+        headers: { "content-type": "application/json" },
+        body: JSON.stringify({ walletAddress: address, signature }),
+      });
+      const verifyData = (await verifyRes.json()) as { error?: string };
+      if (!verifyRes.ok) {
+        throw new Error(verifyData.error ?? "Wallet verification failed");
+      }
+      setStatus("Wallet connected");
+      await refreshAccount();
+    } catch (error) {
+      setStatus(error instanceof Error ? error.message : "Wallet connect failed");
+    } finally {
+      setVerifying(false);
+    }
+  }
+
+  async function onTransfer() {
+    if (!account?.account || !amount || Number(amount) <= 0) {
+      setStatus("Enter an amount");
+      return;
+    }
+    setBusy(true);
+    setStatus(null);
+    setTxUrl(null);
+    try {
+      await ensureMonad();
+      if (direction === "deposit") {
+        if (!isConnected || !address) {
+          throw new Error("Connect your wallet first");
+        }
+        const hash = await sendTransactionAsync({
+          to: account.account.inSiteWallet,
+          value: parseEther(amount),
+          chainId: monadMainnet.id,
+        });
+        setStatus("Deposit submitted — waiting for confirmation…");
+        setTxUrl(getExplorerTxUrl(hash));
+      } else {
+        const res = await fetch("/api/trade/withdraw", {
+          method: "POST",
+          headers: { "content-type": "application/json" },
+          body: JSON.stringify({ amountMon: amount }),
+        });
+        const data = (await res.json()) as { txHash?: string; error?: string };
+        if (!res.ok || !data.txHash) {
+          throw new Error(data.error ?? "Withdraw failed");
+        }
+        setStatus("Withdraw sent");
+        setTxUrl(getExplorerTxUrl(data.txHash));
+        await refreshAccount();
+      }
+    } catch (error) {
+      setStatus(error instanceof Error ? error.message : "Transfer failed");
+    } finally {
+      setBusy(false);
+    }
+  }
+
+  const linked = Boolean(account?.linked && account.account);
+  const step = !user ? 1 : !linked ? 2 : 3;
+
+  return (
+    <div className="mx-auto flex w-full max-w-lg flex-col gap-8">
+      <header className="space-y-3 text-center animate-fade-up">
+        <p className="text-sm font-semibold tracking-[0.2em] text-mx-accent uppercase">MonEx</p>
+        <h1 className="font-display text-4xl font-bold tracking-tight text-mx-text md:text-5xl">
+          Trade Assistant
+        </h1>
+        <p className="text-base text-mx-muted">
+          Fund your trading wallet, then buy Nad.fun tokens by mentioning{" "}
+          <span className="text-mx-text">@monexmonad</span> on X.
+        </p>
+      </header>
+
+      <ol className="flex items-center justify-between gap-2 text-xs font-medium text-mx-muted animate-fade-up-delay">
+        {[
+          { n: 1, label: "Log in with X" },
+          { n: 2, label: "Connect wallet" },
+          { n: 3, label: "Transfer MON" },
+        ].map((item) => (
+          <li
+            key={item.n}
+            className={`flex flex-1 flex-col items-center gap-1 ${
+              step >= item.n ? "text-mx-text" : ""
+            }`}
+          >
+            <span
+              className={`flex h-7 w-7 items-center justify-center rounded-full text-xs font-bold ${
+                step > item.n
+                  ? "bg-mx-accent text-mx-bg"
+                  : step === item.n
+                    ? "bg-mx-surface-2 text-mx-accent ring-1 ring-mx-accent"
+                    : "bg-mx-surface-2 text-mx-muted"
+              }`}
+            >
+              {step > item.n ? <Check className="h-3.5 w-3.5" /> : item.n}
+            </span>
+            <span className="text-center leading-tight">{item.label}</span>
+          </li>
+        ))}
+      </ol>
+
+      {/* Step 1 */}
+      <section className="rounded-2xl border border-mx-border bg-mx-surface/80 p-5 backdrop-blur animate-fade-up-delay-2">
+        <div className="mb-3 flex items-center justify-between gap-3">
+          <h2 className="text-sm font-semibold uppercase tracking-wide text-mx-muted">1 · X account</h2>
+          {user ? (
+            <button
+              type="button"
+              onClick={() => void logout()}
+              className="inline-flex items-center gap-1 text-xs text-mx-muted hover:text-mx-text"
+            >
+              <LogOut className="h-3.5 w-3.5" /> Log out
+            </button>
+          ) : null}
+        </div>
+
+        {authLoading ? (
+          <p className="flex items-center gap-2 text-sm text-mx-muted">
+            <Loader2 className="h-4 w-4 animate-spin" /> Checking session…
+          </p>
+        ) : user ? (
+          <div className="flex items-center gap-3">
+            {user.xProfileImage ? (
+              // eslint-disable-next-line @next/next/no-img-element
+              <img src={user.xProfileImage} alt="" className="h-10 w-10 rounded-full" />
+            ) : (
+              <div className="flex h-10 w-10 items-center justify-center rounded-full bg-mx-surface-2">
+                X
+              </div>
+            )}
+            <div>
+              <p className="font-semibold text-mx-text">@{user.xUsername}</p>
+              <p className="text-xs text-mx-muted">Buys on X run as this account</p>
+            </div>
+          </div>
+        ) : (
+          <div className="space-y-3">
+            <p className="text-sm text-mx-muted">Sign in so we know which X account can trade.</p>
+            <Button className="w-full" onClick={() => (window.location.href = "/api/auth/x")}>
+              Log in with X
+            </Button>
+          </div>
+        )}
+      </section>
+
+      {/* Step 2 */}
+      <section
+        className={`rounded-2xl border border-mx-border bg-mx-surface/80 p-5 backdrop-blur ${
+          !user ? "opacity-45 pointer-events-none" : ""
+        }`}
+      >
+        <h2 className="mb-3 text-sm font-semibold uppercase tracking-wide text-mx-muted">
+          2 · Your wallet
+        </h2>
+        <p className="mb-4 text-sm text-mx-muted">
+          This is <span className="text-mx-text">your</span> wallet — you send MON from here into
+          your trading wallet, and withdraw back here.
+        </p>
+
+        {!user ? null : linked ? (
+          <div className="space-y-2">
+            <p className="font-mono text-sm text-mx-text">
+              {shortAddr(account!.account!.connectedWallet)}
+            </p>
+            <p className="text-xs text-mx-muted">
+              Balance ≈ {formatMon(account?.balances?.connectedMon)} MON
+            </p>
+            {isConnected ? (
+              <button
+                type="button"
+                onClick={() => disconnect()}
+                className="text-xs text-mx-muted underline-offset-2 hover:underline"
+              >
+                Disconnect browser wallet
+              </button>
+            ) : null}
+          </div>
+        ) : (
+          <div className="space-y-3">
+            {!isConnected ? (
+              <Button
+                className="w-full"
+                loading={connecting}
+                onClick={() => {
+                  const connector = connectors[0];
+                  if (connector) connect({ connector });
+                }}
+              >
+                <Wallet className="h-4 w-4" /> Connect wallet
+              </Button>
+            ) : (
+              <>
+                <p className="font-mono text-sm text-mx-text">{shortAddr(address!)}</p>
+                <Button className="w-full" loading={verifying} onClick={() => void verifyAndLink()}>
+                  Confirm ownership
+                </Button>
+              </>
+            )}
+          </div>
+        )}
+      </section>
+
+      {/* Step 3 */}
+      <section
+        className={`rounded-2xl border border-mx-border bg-mx-surface/80 p-5 backdrop-blur ${
+          !linked ? "opacity-45 pointer-events-none" : ""
+        }`}
+      >
+        <h2 className="mb-3 text-sm font-semibold uppercase tracking-wide text-mx-muted">
+          3 · Trading wallet
+        </h2>
+        <p className="mb-4 text-sm text-mx-muted">
+          This wallet is controlled by MonEx. Funds here are what{" "}
+          <span className="text-mx-text">@monexmonad</span> spends when you tweet a buy.
+        </p>
+
+        {loadingAccount && user ? (
+          <p className="flex items-center gap-2 text-sm text-mx-muted">
+            <Loader2 className="h-4 w-4 animate-spin" /> Loading…
+          </p>
