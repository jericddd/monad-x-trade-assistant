# MonEx Trade Assistant — environment variables
# Copy to .dev.vars for local Wrangler development.
# See docs/CREDENTIALS.md for which account each value comes from.

# --- Bot account (@monexmonad) — OAuth 1.0a (same as MonEx catch bot) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BOT_USERNAME=monexmonad

# --- Authorized account (only this user may trade) ---
AUTHORIZED_X_USER_ID=

# --- Monad ---
MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_CHAIN_ID=143
MONAD_EXPLORER_TX_URL=https://monadvision.com/tx/

# --- Trade wallet (server-side secret only) ---
TRADE_WALLET_PRIVATE_KEY=

# --- Nad.fun mainnet (official: https://nad.fun/trading.md) ---
NADFUN_LENS_ADDRESS=0x7e78A8DE94f21804F7a17F4E8BF9EC2c872187ea
NADFUN_ALLOWED_ROUTER_ADDRESSES=0x6F6B8F1a20703309951a5127c45B49b1CD981A22,0x0B79d71AE99528D1dB24A4148b5f4F865cc2b137

# --- Trading safety (safe defaults — keep these for stress testing dry-run) ---
TRADING_ENABLED=false
TRADE_DRY_RUN=true
MAX_MON_PER_TRADE=10
MAX_MON_PER_DAY=30
MAX_TRADES_PER_HOUR=3
DEFAULT_SLIPPAGE_BPS=300
MAX_PRICE_IMPACT_BPS=1000
TRADE_DEADLINE_SECONDS=120
MIN_WALLET_RESERVE_MON=1

# --- Local / CI only ---
# USE_MOCK_BLOCKCHAIN=true
# USE_MOCK_X=true
