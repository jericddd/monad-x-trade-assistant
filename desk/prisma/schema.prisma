generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PackVisibility {
  PUBLIC
  HIDDEN
}

enum SupplyType {
  UNLIMITED
  LIMITED
}

enum OpeningSource {
  X
  WEBSITE
}

enum OpeningStatus {
  UNCLAIMED
  CLAIMING
  CLAIMED
  EXPIRED
}

enum DrawMode {
  EQUAL
  ASSET_WEIGHTS
}

enum XProduct {
  MONEX
  MONAD_PACKS
}

enum PackImportStatus {
  PENDING
  PREVIEW
  PUBLISHED
  REJECTED
}

enum ClaimAttemptStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

model User {
  id            String   @id @default(cuid())
  xUserId       String   @unique
  xUsername     String
  xProfileImage String?
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  walletConnections WalletConnection[]
  packOpenings      PackOpening[]
  xCooldown         XCooldown?
  processedXPosts   ProcessedXPost[]
  claimAttempts     ClaimAttempt[]
}

model WalletConnection {
  id                String    @id @default(cuid())
  userId            String    @unique
  walletAddress     String    @unique
  verificationNonce String?
  nonceExpiresAt    DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pack {
  id                           String         @id @default(cuid())
  sourceAssetId                String?
  name                         String
  slug                         String         @unique
  description                  String?
  coverImage                   String?
  totalCards                   Int            @default(0)
  highestAssignedDisplayNumber Int            @default(0)
  active                       Boolean        @default(false)
  websiteEnabled               Boolean        @default(false)
  xEnabled                     Boolean        @default(false)
  featuredOnX                  Boolean        @default(false)
  useAssetPullRates            Boolean        @default(false)
  visibility                   PackVisibility @default(PUBLIC)
  startsAt                     DateTime?
  endsAt                       DateTime?
  rarityMappingConfirmed       Boolean        @default(false)
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  cards        Card[]
  packOpenings PackOpening[]
  packImports  PackImport[]
}

model Card {
  id                String     @id @default(cuid())
  packId            String
  sourceAssetCardId String?
  assetFingerprint  String
  displayNumber     Int
  name              String
  description       String?
  imageUrl          String
  metadata          Json?
  rarityLabel       String?
  assetWeight       Float?
  supplyType        SupplyType @default(UNLIMITED)
  maxSupply         Int?
  claimedCount      Int        @default(0)
  reservedCount     Int        @default(0)
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  pack         Pack          @relation(fields: [packId], references: [id], onDelete: Cascade)
  packOpenings PackOpening[]

  @@unique([packId, displayNumber])
  @@unique([packId, assetFingerprint])
  @@index([packId, active])
}

model PackOpening {
  id              String        @id @default(cuid())
  userId          String
  packId          String
  cardId          String
  source          OpeningSource
  status          OpeningStatus @default(UNCLAIMED)
  sourcePostId    String?       @unique
  idempotencyKey  String?       @unique
  openedAt        DateTime      @default(now())
  expiresAt       DateTime
  claimingAt      DateTime?
  claimedAt       DateTime?
  expiredAt       DateTime?
  walletAddress   String?
  tokenId         String?
  transactionHash String?
  contractAddress String?
  drawMode        DrawMode
  effectiveWeight Float?
  eligibleCount   Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack          Pack           @relation(fields: [packId], references: [id], onDelete: Cascade)
  card          Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  claimAttempts ClaimAttempt[]
  processedPost ProcessedXPost?

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([openedAt(sort: Desc)])
}

model XCooldown {
  id                   String   @id @default(cuid())
  userId               String   @unique
  lastSuccessfulOpenAt DateTime
  nextAvailableAt      DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProcessedXPost {
  id              String    @id @default(cuid())
  xPostId         String
  product         XProduct
  command         String?
  userId          String?
  resultOpeningId String?   @unique
  createdAt       DateTime  @default(now())

  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  opening PackOpening? @relation(fields: [resultOpeningId], references: [id], onDelete: SetNull)

  @@unique([xPostId, product])
  @@index([xPostId])
}

model PackImport {
  id                String           @id @default(cuid())
  packId            String?
  sourceFilename    String
  sourceFingerprint String
  status            PackImportStatus @default(PENDING)
  detectedCardCount Int              @default(0)
  newCardCount      Int              @default(0)
  duplicateCount    Int              @default(0)
  errorCount        Int              @default(0)
  report            Json?
  createdAt         DateTime         @default(now())
  completedAt       DateTime?

  pack Pack? @relation(fields: [packId], references: [id], onDelete: SetNull)
}

model ClaimAttempt {
  id              String             @id @default(cuid())
  openingId       String
  userId          String
  walletAddress   String
  status          ClaimAttemptStatus @default(PENDING)
  transactionHash String?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  opening PackOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([openingId])
}

model ProductEvent {
  id        String   @id @default(cuid())
  eventType String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt(sort: Desc)])
}
