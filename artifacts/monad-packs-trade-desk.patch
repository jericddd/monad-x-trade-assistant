diff --git a/src/app/api/auth/x/debug/route.ts b/src/app/api/auth/x/debug/route.ts
new file mode 100644
index 0000000..7d7c08e
--- /dev/null
+++ b/src/app/api/auth/x/debug/route.ts
@@ -0,0 +1,74 @@
+import { NextRequest, NextResponse } from "next/server";
+
+/**
+ * Temporary credential probe for X OAuth 2.0.
+ * Auth: Authorization: Bearer <CRON_SECRET>
+ * Does not expose secret values — only whether X accepts the client.
+ */
+export async function GET(request: NextRequest) {
+  const auth = request.headers.get("authorization") ?? "";
+  const secret = process.env.OAUTH_DEBUG_SECRET ?? process.env.CRON_SECRET;
+  if (!secret || auth !== `Bearer ${secret}`) {
+    return NextResponse.json({ error: "unauthorized" }, { status: 401 });
+  }
+
+  const clientId = process.env.X_CLIENT_ID?.trim();
+  const clientSecret = process.env.X_CLIENT_SECRET?.trim();
+  const callbackUrl = process.env.X_CALLBACK_URL?.trim();
+
+  const config = {
+    hasClientId: Boolean(clientId),
+    hasClientSecret: Boolean(clientSecret),
+    clientIdLength: clientId?.length ?? 0,
+    clientSecretLength: clientSecret?.length ?? 0,
+    clientIdPrefix: clientId?.slice(0, 6) ?? null,
+    callbackUrl: callbackUrl ?? null,
+    expectedCallback: "https://packs.monexmonad.xyz/api/auth/x/callback",
+    callbackMatches: callbackUrl === "https://packs.monexmonad.xyz/api/auth/x/callback",
+  };
+
+  if (!clientId || !clientSecret || !callbackUrl) {
+    return NextResponse.json({ ok: false, config, probe: null });
+  }
+
+  const basicAuth = Buffer.from(`${clientId}:${clientSecret}`).toString("base64");
+  const res = await fetch("https://api.x.com/2/oauth2/token", {
+    method: "POST",
+    headers: {
+      "Content-Type": "application/x-www-form-urlencoded",
+      Authorization: `Basic ${basicAuth}`,
+    },
+    body: new URLSearchParams({
+      code: "probe_invalid_code",
+      grant_type: "authorization_code",
+      redirect_uri: callbackUrl,
+      code_verifier: "probe_verifier_abcdefghijklmnopqrstuvwxyz0123456789",
+    }),
+  });
+
+  const body = await res.text();
+  let parsed: { error?: string; error_description?: string } = {};
+  try {
+    parsed = JSON.parse(body) as typeof parsed;
+  } catch {
+    parsed = {};
+  }
+
+  // invalid_grant / invalid_request ⇒ client auth worked, code was bad (expected for probe)
+  // invalid_client / unauthorized_client ⇒ bad client id/secret
+  const clientAccepted =
+    parsed.error === "invalid_grant" ||
+    parsed.error === "invalid_request" ||
+    /code|verifier|grant/i.test(parsed.error_description ?? "");
+
+  return NextResponse.json({
+    ok: clientAccepted,
+    config,
+    probe: {
+      status: res.status,
+      error: parsed.error ?? null,
+      errorDescription: parsed.error_description ?? body.slice(0, 240),
+      clientAccepted,
+    },
+  });
+}
