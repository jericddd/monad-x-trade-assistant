From 9a64bfb6a88de1f9e6c8d2d93dbf6bad47600dda Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursoragent@cursor.com>
Date: Fri, 17 Jul 2026 07:07:59 +0000
Subject: [PATCH 30/41] Add live desk polling so balances and activity update
 without refresh

Silent 3s polls plus focus/visibility refresh keep Funds, Portfolio, and
Activity current during demos; transient API errors no longer clear state.
---
 src/components/trade/trade-desk.tsx | 56 +++++++++++++++++++++++------
 1 file changed, 46 insertions(+), 10 deletions(-)

diff --git a/src/components/trade/trade-desk.tsx b/src/components/trade/trade-desk.tsx
index e5d871f..40a04a7 100644
--- a/src/components/trade/trade-desk.tsx
+++ b/src/components/trade/trade-desk.tsx
@@ -218,7 +218,7 @@ export function TradeDesk() {
     window.history.replaceState({}, "", "/");
   }, []);
 
-  const refreshAccount = useCallback(async () => {
+  const refreshAccount = useCallback(async (opts?: { silent?: boolean }) => {
     if (!user) {
       setAccount(null);
       setAccountReady(false);
@@ -226,26 +226,29 @@ export function TradeDesk() {
       setRecentTrades([]);
       return;
     }
-    setLoadingAccount(true);
+    if (!opts?.silent) setLoadingAccount(true);
     try {
       const res = await fetch("/api/trade/account");
       const data = (await res.json()) as TradeAccountPayload;
       if (!res.ok) {
-        setStatus(data.error ?? "Could not load account");
-        setAccount(null);
+        // Keep last-known state on silent poll failures so the desk doesn't flicker.
+        if (!opts?.silent) {
+          setStatus(data.error ?? "Could not load account");
+          setAccount(null);
+        }
         return;
       }
       setAccount(data);
     } catch {
-      setStatus("Could not load account");
+      if (!opts?.silent) setStatus("Could not load account");
     } finally {
-      setLoadingAccount(false);
+      if (!opts?.silent) setLoadingAccount(false);
       setAccountReady(true);
     }
   }, [user]);
 
   const refreshPortfolio = useCallback(
-    async (page = activityPage) => {
+    async (page = activityPage, opts?: { silent?: boolean }) => {
       if (!user) {
         setHoldings([]);
         setRecentTrades([]);
@@ -255,7 +258,7 @@ export function TradeDesk() {
         setActivityHasPrev(false);
         return;
       }
-      setLoadingPortfolio(true);
+      if (!opts?.silent) setLoadingPortfolio(true);
       try {
         const qs = new URLSearchParams({ page: String(page), limit: "50" });
