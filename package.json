{
  "name": "monad-x-trade-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "MonEx Trade Assistant — personal X command bot for Nad.fun token purchases on Monad",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "viem": "^2.31.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.16.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.25.0"
  }
}
